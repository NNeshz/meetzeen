{
  "name": "meetzeen",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "envs": "turbo envs",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "shadcn": "bun --filter @meetzeen/ui shadcn",
    "db:generate": "bun --filter @meetzeen/database db:generate",
    "db:migrate": "bun --filter @meetzeen/database db:migrate",
    "db:migrate:dev": "bun --filter @meetzeen/database db:migrate:dev",
    "db:push": "bun --filter @meetzeen/database db:push",
    "db:reset": "bun --filter @meetzeen/database db:reset",
    "db:studio": "bun --filter @meetzeen/database db:studio",
    "clean-workspaces": "turbo clean-workspace && rm -rf node_modules"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.8",
    "prettier": "^3.7.4",
    "turbo": "^2.6.3",
    "typescript": "5.9.3",
    "esbuild": "^0.24.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
