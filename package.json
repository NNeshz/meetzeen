{
  "name": "meetzeen",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "envs": "turbo envs",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "shadcn": "bun --filter @meetzeen/ui shadcn",
    "prisma": "bun --filter @meetzeen/database prisma-command",
    "clean-workspaces": "turbo clean-workspace && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.7.3",
    "turbo": "^2.6.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/swagger": "^1.3.1",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.0.1",
    "@react-three/fiber": "^9.4.2",
    "@react-three/postprocessing": "^3.0.4",
    "@sinclair/typebox": "^0.34.41",
    "@tabler/icons-react": "^3.35.0",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/pg": "^8.15.6",
    "better-auth": "^1.4.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.7.1",
    "next": "^16.0.7",
    "next-i18next": "^15.4.3",
    "next-intl": "^4.5.8",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "postprocessing": "^6.38.0",
    "prisma": "^7.0.1",
    "react-i18next": "^16.3.5",
    "tailwind": "^4.0.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.181.2",
    "tw-animate-css": "^1.4.0"
  }
}
