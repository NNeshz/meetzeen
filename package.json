    "react-i18next": "^16.4.0",
    "resend": "^6.5.2",
    "tailwind": "^4.0.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.181.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.13"
