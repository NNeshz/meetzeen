model Company {
  id          String  @id @default(uuid())
  imageUrl    String
  name        String
  slugName    String
  phoneNumber String
  slogan      String?
  address     String?
  workDays    String[]
  startHour   String
  startMinute String
  startAmPm   String
  endHour     String
  endMinute   String
  endAmPm     String

  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([phoneNumber])
  @@index([userId])
}
