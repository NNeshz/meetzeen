enum ExceptionType {
  DAY_OFF
  UNAVAILABLE
  EXTRA_SHIFT
}

enum ExceptionRecurrence {
  NONE
  WEEKLY
}

model Category {
  id   String @id @default(uuid())
  name String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employees Employee[] @relation("EmployeeCategories")
  services  Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Employee {
  id          String  @id @default(uuid())
  imageUrl    String?
  name        String
  phoneNumber String
  email       String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  schedules    EmployeeSchedule[]
  exceptions   EmployeeException[]
  categories   Category[]          @relation("EmployeeCategories")
  appointments AppointmentSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model EmployeeSchedule {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  startTime String
  endTime   String

  order    Int     @default(1)
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, dayOfWeek, startTime, endTime])
  @@index([employeeId, dayOfWeek])
}

model EmployeeException {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  type ExceptionType

  date DateTime?

  recurrence  ExceptionRecurrence @default(NONE)
  dayOfWeek   Int?
  repeatUntil DateTime?

  startTime String?
  endTime   String?

  isAvailable Boolean
  reason      String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId, date])
  @@index([employeeId, dayOfWeek])
}

model Service {
  id       String @id @default(uuid())
  name     String
  duration String
  price    Float

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  appointments AppointmentSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Appointment {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  customerName  String
  customerPhone String?
  customerEmail String?

  date     DateTime
  duration Int
  status   String

  slots AppointmentSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppointmentSlot {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  startTime DateTime
  endTime   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
