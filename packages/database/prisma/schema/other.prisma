model Category {
  id   String @id @default(uuid())
  name String

  // Relaciones actualizadas
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  employees Employee[] @relation("EmployeeCategories")
  services  Service[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Employee {
  id          String  @id @default(uuid())
  imageUrl    String?
  name        String
  phoneNumber String
  email       String

  // Relaciones actualizadas
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  schedules    EmployeeSchedule[]
  exceptions   EmployeeException[]
  categories   Category[]          @relation("EmployeeCategories")
  appointments AppointmentSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model EmployeeSchedule {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  dayOfWeek Int // 0 = domingo, 1 = lunes ... 6 = sábado
  startTime String // Ej: "08:00"
  endTime   String // Ej: "12:00"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmployeeException {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  date        DateTime 
  startTime   String? 
  endTime     String? 
  isAvailable Boolean 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Service {
  id       String @id @default(uuid())
  name     String
  duration String
  price    Float

  // Relaciones actualizadas
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  appointments AppointmentSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Appointment {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  customerName  String
  customerPhone String?
  customerEmail String?

  date     DateTime // día + hora de inicio (UTC)
  duration Int // minutos totales de la cita
  status   String // pending, confirmed, cancelled, etc.

  // Relación con subcitas (cada servicio dentro de la cita)
  slots AppointmentSlot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppointmentSlot {
  id            String      @id @default(uuid())
  appointmentId String
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  startTime DateTime // hora exacta inicio (UTC)
  endTime   DateTime // hora exacta fin (UTC)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
