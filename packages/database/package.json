{
  "name": "@meetzeen/database",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env drizzle-kit migrate",
    "db:push": "bun --env-file=../../.env drizzle-kit push",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio",
    "db:introspect": "bun --env-file=../../.env drizzle-kit introspect",
    "db:reset": "bun --env-file=../../.env scripts/reset.ts",
    "db:migrate:dev": "bun --env-file=../../.env drizzle-kit generate && bun --env-file=../../.env drizzle-kit migrate"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "5.5.4"
  }
}
